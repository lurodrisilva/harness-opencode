{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "opencode chart values",
  "type": "object",
  "additionalProperties": false,
  "required": ["replicaCount", "image", "auth", "service", "persistence"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "Locked to 1: RWO PVC + single binary instance. Multi-replica needs redesign."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._/-]*[a-z0-9]$"
        },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "oneOf": [
            { "const": "" },
            { "pattern": "^sha256:[a-f0-9]{64}$" }
          ]
        },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": { "name": { "type": "string", "minLength": 1 } }
          }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "passwordKey", "username", "generatedPasswordLength"],
      "properties": {
        "enabled": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "passwordKey": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "generatedPasswordLength": { "type": "integer", "minimum": 16, "maximum": 256 }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": { "type": "string" },
        "openaiKey": { "type": "string" },
        "anthropicKey": { "type": "string" }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "config"],
      "properties": {
        "data":   { "$ref": "#/$defs/persistenceVolume" },
        "config": { "$ref": "#/$defs/persistenceVolume" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "port"],
      "properties": {
        "type": { "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["path", "pathType"],
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": { "enum": ["Prefix", "Exact", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hosts": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "secretName": { "type": "string" }
            }
          }
        }
      },
      "if":   { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["tls"], "properties": { "tls": { "minItems": 1 } } }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressFrom": { "type": "array" },
        "egressExcept": {
          "type": "array",
          "items": {
            "type": "string",
            "$comment": "Permits IPv4 (10.0.0.0/8) and IPv6 (fd00::/8) CIDRs.",
            "pattern": "^([0-9.]+|[0-9a-fA-F:]+)/[0-9]+$"
          }
        },
        "extraEgress": { "type": "array" }
      }
    },
    "resources": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["liveness", "readiness", "startup"],
      "properties": {
        "liveness":  { "type": "object" },
        "readiness": { "type": "object" },
        "startup":   { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "priorityClassName": { "type": "string" },
    "topologySpreadConstraints": { "type": "array" }
  },
  "allOf": [
    {
      "$comment": "Reject auth.enabled=false combined with ingress.enabled=true — that ships an unauthenticated, internet-reachable opencode (RCE-equivalent per README). `required` inside `if` ensures defaults that omit the field don't bypass the gate.",
      "if": {
        "properties": {
          "auth":    { "properties": { "enabled": { "const": false } }, "required": ["enabled"] },
          "ingress": { "properties": { "enabled": { "const": true  } }, "required": ["enabled"] }
        },
        "required": ["auth", "ingress"]
      },
      "then": {
        "properties": {
          "ingress": {
            "properties": { "enabled": { "const": false } }
          }
        }
      }
    }
  ],
  "$defs": {
    "persistenceVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "size", "accessModes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany", "ReadWriteOncePod"] }
        },
        "annotations": { "type": "object" }
      }
    }
  }
}
